[Unit]
Description=Plasma Login Manager
Documentation=man:plasmalogin(1) man:plasmalogin.conf(5)
Conflicts=kmsconvt@tty1.service
After=systemd-user-sessions.service kmsconvt@tty1.service plymouth-quit.service systemd-logind.service
PartOf=graphical.target
StartLimitIntervalSec=30
StartLimitBurst=2

[Service]
ExecStart=/usr/bin/plasmalogin
Restart=always

[Install]
Alias=display-manager.service
